#!/usr/bin/env zsh

SKETCHYBAR_CONFIG="$HOME/.config/sketchybar"
PROFILE_FILE="$SKETCHYBAR_CONFIG/.display_profile"
PROFILE=""

# Optional override:
#   printf "laptop" > ~/.config/sketchybar/.display_profile
#   printf "home" > ~/.config/sketchybar/.display_profile
#   printf "work" > ~/.config/sketchybar/.display_profile
#   # legacy alias:
#   printf "desktop" > ~/.config/sketchybar/.display_profile
#   rm ~/.config/sketchybar/.display_profile
# Then reload: sketchybar --reload
if [[ -f "$PROFILE_FILE" ]]; then
    PROFILE="$(<"$PROFILE_FILE")"
fi

# This is used to determine if a monitor is used
# Since the notch is -only- on the laptop, if a monitor isn't used,
# then that means the internal display is used ¯\_(ツ)_/¯
MAIN_DISPLAY=$(system_profiler SPDisplaysDataType | grep -B 3 'Main Display:' | awk '/Display Type/ {print $3}')

if [[ "$PROFILE" = "laptop" ]]; then
    source "$SKETCHYBAR_CONFIG/sketchybarrc-laptop"
elif [[ "$PROFILE" = "home" ]]; then
    source "$SKETCHYBAR_CONFIG/sketchybarrc-home-desktop"
elif [[ "$PROFILE" = "work" ]]; then
    source "$SKETCHYBAR_CONFIG/sketchybarrc-work-desktop"
elif [[ "$PROFILE" = "desktop" ]]; then
    source "$SKETCHYBAR_CONFIG/sketchybarrc-home-desktop"
elif [[ $MAIN_DISPLAY = "Built-in" ]]; then
    source "$SKETCHYBAR_CONFIG/sketchybarrc-laptop"
else
    source "$SKETCHYBAR_CONFIG/sketchybarrc-home-desktop"
fi
